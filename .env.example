APP_NAME=HighLevel AI Lead Bridge
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATABASE_AUTO_CREATE=true
MAX_REQUEST_SIZE_BYTES=1048576

WEBHOOK_SHARED_SECRET=replace-me
WEBHOOK_SECRET_HEADER=X-Webhook-Secret

LLM_PROVIDER=mock
LLM_MODEL=demo
LLM_TIMEOUT_SECONDS=30
LLM_SECONDARY_PROVIDER=
LLM_INPUT_COST_PER_MILLION=
LLM_OUTPUT_COST_PER_MILLION=

OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_BASE_URL=
LLM_API_KEY=

NOTIFICATION_PROVIDER=none
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

HIGHLEVEL_SYNC_ENABLED=false
HIGHLEVEL_API_BASE_URL=
HIGHLEVEL_API_TOKEN=
HIGHLEVEL_LOCATION_ID=
HIGHLEVEL_SUMMARY_TAG=ai-reviewed
HIGHLEVEL_HIGH_INTENT_TAG=high-intent
HIGHLEVEL_RECOMMENDED_ACTION_FIELD_ID=

MAX_RETRY_ATTEMPTS=3
HTTP_TIMEOUT_SECONDS=15
